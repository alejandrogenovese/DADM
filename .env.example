# DADM — plantilla de variables de entorno.
# Copiar a .env y completar con valores reales:  cp .env.example .env

# Puerto del servidor
PORT=8321

# MongoDB — conexión de la app
MONGO_URI=mongodb://usuario:password@localhost:27017/?authSource=admin
MONGO_DB=DADM

# Credenciales root del contenedor MongoDB (usadas por docker-compose)
MONGO_ROOT_USERNAME=usuario
MONGO_ROOT_PASSWORD=password

# Autenticación
# AUTH_SECRET: secreto para firmar la sesión (usar uno largo y aleatorio)
# ADMIN_USER / ADMIN_PASS: usuario Architect Lead inicial (se crea si no hay usuarios)
AUTH_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
ADMIN_USER=admin
ADMIN_PASS=cambiar
