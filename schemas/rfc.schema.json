{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dadm.bancogalicia.com.ar/schemas/rfc/1.0.0",
  "title": "RFC — Request for Comments (DADM)",
  "description": "Documento RFC de Arquitectura Data, Banco Galicia. Los comentarios y el cierre son datos estructurados gestionados por DADM, no secciones editables del cuerpo.",
  "type": "object",
  "required": ["id", "tipo", "titulo", "estado", "autores", "sponsor", "fecha_creacion", "cuerpo"],
  "properties": {
    "id": { "type": "string", "pattern": "^RFC-\\d{4}$", "readOnly": true },
    "tipo": { "const": "rfc" },
    "titulo": { "type": "string", "minLength": 10, "maxLength": 200 },
    "descripcion_corta": { "type": "string", "maxLength": 300 },
    "estado": { "type": "string", "enum": ["borrador", "en_comentarios", "cerrado"], "default": "borrador" },
    "autores": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/persona" } },
    "sponsor": {
      "allOf": [{ "$ref": "#/$defs/persona" }],
      "description": "Reviewer principal / quien toma la decisión final al cierre."
    },
    "ventana_comentarios": {
      "type": "object",
      "description": "Requerida para pasar a estado en_comentarios. Al vencer, DADM notifica al autor.",
      "required": ["desde", "hasta"],
      "properties": {
        "desde": { "type": "string", "format": "date" },
        "hasta": { "type": "string", "format": "date" }
      }
    },
    "fecha_esperada_decision": { "type": "string", "format": "date" },
    "stakeholders": {
      "type": "array",
      "description": "Áreas/personas convocadas a revisar. Si se cargan revisores con tipo 'requerida', DADM exige su estado de revisión antes del cierre.",
      "items": {
        "type": "object",
        "required": ["nombre"],
        "properties": {
          "nombre": { "type": "string", "description": "Persona o área. Ej: Gobierno de Datos" },
          "tipo_revision": { "type": "string", "enum": ["requerida", "opcional"], "default": "opcional" },
          "estado_revision": { "type": "string", "enum": ["pendiente", "revisado"], "default": "pendiente", "readOnly": true }
        }
      }
    },
    "tags": { "type": "array", "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }, "uniqueItems": true },
    "relaciones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tipo", "destino"],
        "properties": {
          "tipo": { "type": "string", "enum": ["adr_resultante", "relacionado_con"] },
          "destino": { "type": "string" },
          "nota": { "type": "string" }
        }
      }
    },
    "fecha_creacion": { "type": "string", "format": "date", "readOnly": true },
    "fecha_actualizacion": { "type": "string", "format": "date", "readOnly": true },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+$", "readOnly": true },
    "historial": {
      "type": "array", "readOnly": true,
      "items": {
        "type": "object",
        "required": ["version", "fecha", "autor", "cambio"],
        "properties": {
          "version": { "type": "string" },
          "fecha": { "type": "string", "format": "date" },
          "autor": { "type": "string" },
          "cambio": { "type": "string" }
        }
      }
    },
    "comentarios": {
      "type": "array",
      "description": "Gestionados por DADM durante la ventana. Para cerrar el RFC, todo comentario debe tener resolución.",
      "items": {
        "type": "object",
        "required": ["num", "fecha", "revisor", "tipo", "comentario"],
        "properties": {
          "num": { "type": "integer", "readOnly": true },
          "fecha": { "type": "string", "format": "date", "readOnly": true },
          "revisor": { "type": "string" },
          "seccion": { "type": "string", "description": "Código o título de la sección comentada. Opcional." },
          "tipo": { "type": "string", "enum": ["sugerencia", "objecion", "pregunta", "aclaracion"] },
          "comentario": { "type": "string" },
          "resolucion": { "type": "string", "enum": ["aceptado", "rechazado", "pospuesto", "aclarado"] },
          "detalle_resolucion": { "type": "string", "description": "Obligatorio si resolucion=rechazado" }
        },
        "if": { "properties": { "resolucion": { "const": "rechazado" } }, "required": ["resolucion"] },
        "then": { "required": ["detalle_resolucion"] }
      }
    },
    "cierre": {
      "type": "object",
      "description": "Se completa al cerrar. Si resolucion acepta, DADM ofrece crear el ADR y carga la relación adr_resultante.",
      "required": ["resolucion", "fecha", "decidido_por"],
      "properties": {
        "resolucion": { "type": "string", "enum": ["aceptado", "aceptado_con_cambios", "rechazado", "pospuesto"] },
        "fecha": { "type": "string", "format": "date", "readOnly": true },
        "decidido_por": { "type": "string" },
        "observaciones": { "type": "string" },
        "artefactos_derivados": {
          "type": "array",
          "items": { "type": "string", "description": "IDs: ADR-NNN, HLD-NNNN, TSR-NNNN" }
        }
      }
    },
    "cuerpo": {
      "type": "array",
      "minItems": 1,
      "description": "Secciones ordenadas. Qué secciones son obligatorias NO se fija en este schema: lo define la configuración vigente en catalogos.json (editable por administradores de DADM). La app valida la presencia de las obligatorias al salir del estado borrador. Default de fábrica: resumen_ejecutivo, problema_motivacion, propuesta, alternativas.",
      "items": { "$ref": "#/$defs/seccion" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "estado": { "const": "en_comentarios" } }, "required": ["estado"] },
      "then": { "required": ["ventana_comentarios"] }
    },
    {
      "if": { "properties": { "estado": { "const": "cerrado" } }, "required": ["estado"] },
      "then": { "required": ["cierre"] }
    }
  ],
  "$defs": {
    "persona": {
      "type": "object",
      "required": ["nombre"],
      "properties": {
        "nombre": { "type": "string" },
        "rol": { "type": "string" },
        "equipo": { "type": "string" }
      }
    },
    "seccion": {
      "type": "object",
      "required": ["codigo", "bloques"],
      "properties": {
        "codigo": { "type": "string", "enum": ["resumen_ejecutivo", "problema_motivacion", "propuesta", "alternativas", "trade_offs", "riesgos", "cuestiones_abiertas", "cronograma", "fuera_de_alcance", "stakeholders_revisores", "referencias", "anexo", "custom"] },
        "titulo": { "type": "string" },
        "bloques": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bloque" } },
        "subsecciones": {
          "type": "array",
          "description": "Subsecciones (ej: 2.1 Estado actual, 3.2 Diseño propuesto). Las sugeridas están en catalogos.json; también pueden ser libres.",
          "items": { "$ref": "#/$defs/subseccion" }
        }
      },
      "if": { "properties": { "codigo": { "enum": ["custom", "anexo"] } } },
      "then": { "required": ["codigo", "titulo", "bloques"] }
    },
    "subseccion": {
      "type": "object",
      "required": ["titulo", "bloques"],
      "properties": {
        "codigo": { "type": "string" },
        "titulo": { "type": "string" },
        "bloques": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/bloque" } }
      }
    },
    "bloque": {
      "type": "object",
      "required": ["tipo"],
      "oneOf": [
        {
          "properties": { "tipo": { "const": "texto" }, "contenido": { "type": "string" } },
          "required": ["tipo", "contenido"]
        },
        {
          "properties": {
            "tipo": { "const": "tabla_libre" },
            "encabezados": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "filas": { "type": "array", "items": { "type": "array", "items": { "type": "string" } } },
            "titulo": { "type": "string" }
          },
          "required": ["tipo", "encabezados", "filas"]
        },
        {
          "properties": {
            "tipo": { "const": "tabla_tipada" },
            "plantilla": { "type": "string", "enum": ["opciones_evaluadas", "comparativa", "riesgos", "glosario", "raci", "cronograma", "matriz_asignacion", "stakeholders"] },
            "filas": { "type": "array", "items": { "type": "object", "additionalProperties": { "type": "string" } } }
          },
          "required": ["tipo", "plantilla", "filas"]
        },
        {
          "properties": {
            "tipo": { "const": "imagen" },
            "recurso": { "type": "string" },
            "epigrafe": { "type": "string" }
          },
          "required": ["tipo", "recurso"]
        },
        {
          "properties": {
            "tipo": { "const": "codigo" },
            "lenguaje": { "type": "string", "default": "sql" },
            "contenido": { "type": "string" }
          },
          "required": ["tipo", "contenido"]
        },
        {
          "properties": {
            "tipo": { "const": "callout" },
            "estilo": { "type": "string", "enum": ["info", "decision", "advertencia", "cita"], "default": "info" },
            "contenido": { "type": "string" }
          },
          "required": ["tipo", "contenido"]
        }
      ]
    }
  }
}
